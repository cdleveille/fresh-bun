{
  "name": "fresh-bun",
  "version": "0.1.0",
  "description": "Single-page web app project template curated for performance, developer experience, and type safety.",
  "author": "Chris Leveille",
  "license": "MIT No Attribution",
  "type": "module",
  "scripts": {
    "postinstall": "bun scripts/lefthook.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "tsc": "tsc -p tsconfig.json",
    "concurrent": "concurrently --prefix \"[{name}]\" -c \"bgBlue.bold,bgGreen.bold\"",
    "dev": "bun concurrent --names \"server,client\" \"bun --hot src/server/index.ts\" \"bunx --bun vite\"",
    "build:client": "bunx --bun vite build && bun scripts/workbox.ts",
    "build:server": "bun build --compile --minify --sourcemap --bytecode --target bun --outfile dist/main src/server/index.ts",
    "build:app": "bun build:client && bun build:server",
    "build": "bun build:app",
    "start": "bun src/server/index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@evilmartians/lefthook": "^2.1.4",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tanstack/router-plugin": "^1.167.8",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-static-copy": "^4.0.0",
    "vite-plugin-svgr": "^4.5.0",
    "workbox-build": "^7.4.0"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.7",
    "hono": "^4.12.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
