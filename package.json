{
  "name": "fresh-bun",
  "version": "0.1.0",
  "description": "Single-page web app project template curated for performance, developer experience, and type safety.",
  "author": "Chris Leveille",
  "license": "MIT No Attribution",
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "tsc": "tsc -p tsconfig.json",
    "concurrent": "concurrently --kill-others --prefix \"[{name}]\" -c \"bgBlue.bold,bgGreen.bold\"",
    "dev": "bun concurrent --names \"server,client\" \"bun --hot src/server/app.ts\" \"bunx --bun vite\"; stty sane",
    "build:client": "bunx --bun vite build && bun src/scripts/workbox.ts",
    "build:server": "bun src/scripts/assets.ts && NODE_ENV=production bun build --compile --minify --bytecode --target bun --outfile dist/app src/server/app.ts",
    "build:app": "bun build:client && bun build:server && bun src/scripts/clean.ts",
    "build": "bun build:app",
    "start": "bun src/server/app.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@evilmartians/lefthook": "^2.1.9",
    "@rolldown/plugin-babel": "^0.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.1",
    "vite-plugin-svgr": "^5.2.0",
    "workbox-build": "^7.4.1"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "hono": "^4.12.26",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
